{
  "manifest_version": 3,
  "name": "Gemini Actus Browser Controller",
  "version": "1.0",
  "description": "Allows Gemini Actus agent to control the browser.",
  "permissions": [
    "sidePanel",
    "debugger",
    "activeTab",
    "scripting",
    "nativeMessaging",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Gemini Actus Browser Controller"
  },
  "key": ""
}
